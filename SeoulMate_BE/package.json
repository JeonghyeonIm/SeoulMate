{
  "name": "seoulmate-be",
  "version": "1.0.0",
  "private": true,
  "description": "SeoulMate backend service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "sync:public-data": "npm run build && node dist/jobs/runPublicDataSync.js",
    "convert:coordinates": "npm run build && node dist/jobs/runCoordinateConversion.js",
    "repair:coordinates": "npm run build && node dist/jobs/runAddressCoordinateRepair.js",
    "normalize:categories": "npm run build && node dist/jobs/runPublicDataCategoryNormalization.js",
    "normalize:kakao-categories": "npm run build && node dist/jobs/runKakaoPlaceCategoryNormalization.js",
    "sync:weather": "npm run build && node dist/jobs/runWeatherSync.js",
    "sync:living-population": "npm run build && node dist/jobs/runLivingPopulationSync.js",
    "prepare": "node scripts/setupHusky.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "proj4": "^2.20.8",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/proj4": "^2.5.6",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  }
}
